# ═══════════════════════════════════════════════════════════════
# Autosuficiencia — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# All variables prefixed with VITE_ are exposed to client-side code.
# ═══════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────
VITE_APP_NAME=Autosuficiencia
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_LANG=es

# ─── Pyodide ───────────────────────────────────────────────────
# Set to "false" to disable Pyodide Python execution entirely
VITE_PYODIDE_ENABLED=true

# ─── Debug ─────────────────────────────────────────────────────
# Set to "true" to enable debug mode (KB validation warnings, diagnostic tools)
VITE_DEBUG_MODE=false

# ─── Security ──────────────────────────────────────────────────
# Maximum file upload size in MB for document import (default: 10)
VITE_MAX_UPLOAD_SIZE_MB=10

# Comma-separated list of allowed origins for CORS (if using external resources)
VITE_ALLOWED_ORIGINS=

# CSP report-uri for monitoring policy violations (optional, requires endpoint)
VITE_CSP_REPORT_URI=

# ─── Features ──────────────────────────────────────────────────
# Enable/disable the AI Assistant chat widget
VITE_AI_ASSISTANT_ENABLED=true

# Enable/disable document import (PDF, TXT, CSV, URL)
VITE_DOCUMENT_IMPORT_ENABLED=true

# Enable/disable Knowledge Base persistence to IndexedDB
VITE_KB_PERSISTENCE_ENABLED=true
