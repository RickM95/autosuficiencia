// /rules/checkin_protocols.json
{
  "daily_checkin": {
    "trigger": "every_24_hours",
    "questions": [
      {
        "id": "q1",
        "en": "Did you complete yesterday's planned actions? (Y/N/Partial + details)",
        "es": "¿Completó las acciones planificadas de ayer? (S/N/Parcial + detalles)"
      },
      {
        "id": "q2",
        "en": "On a scale of 1-10, how was your energy/mood today?",
        "es": "En una escala del 1 al 10, ¿cómo estuvo su energía/estado de ánimo hoy?"
      },
      {
        "id": "q3",
        "en": "What's the one thing you'll do now?",
        "es": "¿Qué es lo único que va a hacer ahora?"
      }
    ],
    "data_capture": ["completion_status", "energy_mood_rating", "forward_commitment"]
  },
  "weekly_review": {
    "trigger": "every_7_days",
    "facilitation": {
      "en": "Compare planned vs. actual, recalculate domain scores, identify biggest obstacle, adjust next week's actions.",
      "es": "Compare planificado vs. real, recalcule puntajes de dominio, identifique el mayor obstáculo, ajuste acciones de la próxima semana."
    },
    "output": "updated_plan_snippets"
  },
  "monthly_recalibration": {
    "trigger": "every_30_days",
    "actions": [
      "update_all_domain_scores",
      "if_overall_score_increased_10pts -> phase_shift_check",
      "if_score_dropped_5pts -> plan_rescue_protocol",
      "long_term_trend_analysis"
    ]
  }
}