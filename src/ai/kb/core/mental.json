    { "id": "act_men_022", "trigger": { "conditions": [] }, "name": { "en": "Limit News Consumption", "es": "Limitar el Consumo de Noticias" }, "steps": [ { "order": 1, "instruction": { "en": "Check news once a day for 10 minutes max. Avoid before bed.", "es": "Revise las noticias una vez al día por 10 minutos máximo. Evite antes de dormir." } } ], "outcome_metric": "MEDIA_DIET" },
    { "id": "act_men_023", "trigger": { "conditions": [] }, "name": { "en": "Mindful Scripture Meditation", "es": "Meditación Consciente en las Escrituras" }, "steps": [ { "order": 1, "instruction": { "en": "Read one verse slowly, then sit quietly for 2 minutes pondering its meaning.", "es": "Lea un versículo lentamente, luego siéntese en silencio por 2 minutos meditando su significado." } } ], "outcome_metric": "SPIRITUAL_CALM" },
    { "id": "act_men_024", "trigger": { "conditions": [] }, "name": { "en": "Self-Compassion Break", "es": "Pausa de Autocompasión" }, "steps": [ { "order": 1, "instruction": { "en": "Place hand on heart and say, 'This is hard. I am not alone. May I be kind to myself.'", "es": "Coloque la mano en el corazón y diga: 'Esto es difícil. No estoy solo. Que pueda ser amable conmigo mismo'." } } ], "outcome_metric": "SELF_KINDNESS" },
