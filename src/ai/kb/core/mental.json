      "steps": [
        { "order": 1, "instruction": { "en": "Think of someone safe (family, ministering brother/sister, friend). Contact them today.", "es": "Piense en alguien seguro (familiar, hermano/a ministrante, amigo). Comuníquese con ellos hoy." } }
      ],
      "outcome_metric": "SUPPORT_CONTACT"
    },
    {
      "id": "act_men_005",
      "trigger": { "conditions": ["dt_men_002:true"] },
      "name": { "en": "Join a Support Group", "es": "Unirse a un Grupo de Apoyo" },
      "steps": [
        { "order": 1, "instruction": { "en": "Find a local or online support group (Church addiction recovery, NAMI).", "es": "Encuentre un grupo de apoyo local o en línea (recuperación de adicciones de la Iglesia, NAMI)." } }
      ],
      "outcome_metric": "GROUP_ENGAGEMENT"
    },
    {
