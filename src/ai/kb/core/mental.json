// /core/mental.json
{
  "domain_id": "mental",
  "name": {
    "en": "Mental & Emotional Stability",
    "es": "Estabilidad Mental y Emocional"
  },
  "description": {
    "en": "CBT-informed strategies to renew the mind, build resilience, and maintain emotional balance with faith.",
    "es": "Estrategias informadas por TCC para renovar la mente, desarrollar resiliencia y mantener el equilibrio emocional con fe."
  },
  "principles": [
    {
      "id": "mnt_pr_1",
      "title": { "en": "Renewing the Mind (Romans 12:2)", "es": "Renovación de la Mente (Romanos 12:2)" },
      "description": {
        "en": "Replace worldly thought patterns with truth, prayer, and scripture.",
        "es": "Reemplace los patrones de pensamiento mundanos con verdad, oración y Escrituras."
      }
    },
    {
      "id": "mnt_pr_2",
      "title": { "en": "Hope in Christ", "es": "Esperanza en Cristo" },
      "description": {
        "en": "Mental stability is anchored in the Atonement of Jesus Christ, which provides strength and healing.",
        "es": "La estabilidad mental está anclada en la Expiación de Jesucristo, que brinda fortaleza y sanación."
      }
    },
    {
      "id": "mnt_pr_3",
      "title": { "en": "Agency & Response-Ability", "es": "Albedrío y Capacidad de Respuesta" },
      "description": {
        "en": "You cannot always control circumstances, but you can choose your response. Focus on what you can change.",
        "es": "No siempre puede controlar las circunstancias, pero puede elegir su respuesta. Concéntrese en lo que puede cambiar."
      }
    },
    {
      "id": "mnt_pr_4",
      "title": { "en": "Accountability & Confession", "es": "Responsabilidad y Confesión" },
      "description": {
        "en": "Share burdens with a trusted friend, leader, or professional. Transparency promotes healing.",
        "es": "Comparta las cargas con un amigo de confianza, líder o profesional. La transparencia promueve la sanación."
      }
    },
    {
      "id": "mnt_pr_5",
      "title": { "en": "Gratitude as a Spiritual Discipline", "es": "La Gratitud como Disciplina Espiritual" },
      "description": {
        "en": "Counting blessings daily protects against despair and draws spiritual power.",
        "es": "Contar las bendiciones diariamente protege contra la desesperación y atrae poder espiritual."
      }
    }
  ],
  "decision_trees": [
    {
      "id": "dt_men_001",
      "label": { "en": "High Emotional Distress", "es": "Alta Angustia Emocional" },
      "condition": { "field": "profile.assessment.wellbeing.downFrequency", "operator": "in", "value": ["more than half", "nearly every day"] },
      "branches": [
        { "result": "true", "action_ids": ["act_men_001", "act_men_002", "act_men_003"], "priority": "critical" }
      ]
    },
    {
      "id": "dt_men_002",
      "label": { "en": "Lack of Emotional Support", "es": "Falta de Apoyo Emocional" },
      "condition": { "field": "profile.assessment.wellbeing.emotionalSupport", "operator": "eq", "value": false },
      "branches": [
        { "result": "true", "action_ids": ["act_men_004", "act_men_005"] }
      ]
    },
    {
      "id": "dt_men_003",
      "label": { "en": "Negative Thought Loops", "es": "Bucles de Pensamiento Negativo" },
      "condition": { "field": "profile.behavioralTags", "operator": "contains", "value": "negative_thoughts" },
      "branches": [
        { "result": "true", "action_ids": ["act_men_006", "act_men_007"] }
      ]
    },
    {
      "id": "dt_men_004",
      "label": { "en": "Stress Overwhelm", "es": "Abrumamiento por Estrés" },
      "condition": { "field": "profile.assessment.productivity.wasteHoursPerWeek", "operator": "gt", "value": 20 },
      "branches": [
        { "result": "true", "action_ids": ["act_men_008", "act_men_009"] }
      ]
    },
    {
      "id": "dt_men_005",
      "label": { "en": "Suicidal Ideation Referral", "es": "Derivación por Ideación Suicida" },
      "condition": { "field": "profile.assessment.mental.suicidalThoughts", "operator": "eq", "value": true },
      "branches": [
        { "result": "true", "action_ids": ["act_men_010", "act_men_011"], "priority": "emergency" }
      ]
    },
    {
      "id": "dt_men_006",
      "label": { "en": "Gratitude Deficiency", "es": "Deficiencia de Gratitud" },
      "condition": { "field": "profile.scores.spiritual", "operator": "lt", "value": 40 },
      "branches": [
        { "result": "true", "action_ids": ["act_men_012", "act_men_013"] }
      ]
    },
    {
      "id": "dt_men_007",
      "label": { "en": "Low Self-Efficacy", "es": "Baja Autoeficacia" },
      "condition": { "field": "profile.assessment.goals.confidence", "operator": "lt", "value": 4 },
      "branches": [
        { "result": "true", "action_ids": ["act_men_014", "act_men_015"] }
      ]
    },
    {
      "id": "dt_men_008",
      "label": { "en": "Isolation Patterns", "es": "Patrones de Aislamiento" },
      "condition": { "field": "profile.assessment.social.socialContactDays", "operator": "lt", "value": 2 },
      "branches": [
        { "result": "true", "action_ids": ["act_men_016"] }
      ]
    },
    {
      "id": "dt_men_009",
      "label": { "en": "Sleep-Impacted Mood", "es": "Estado de Ánimo Afectado por el Sueño" },
      "condition": {
        "type": "and",
        "conditions": [
          { "field": "profile.assessment.wellbeing.sleepHours", "operator": "lt", "value": 6 },
          { "field": "profile.assessment.wellbeing.downFrequency", "operator": "in", "value": ["more than half"] }
        ]
      },
      "branches": [
        { "result": "true", "action_ids": ["act_men_017"] }
      ]
    },
    {
      "id": "dt_men_010",
      "label": { "en": "Post-Trauma Signs", "es": "Signos de Trauma" },
      "condition": { "field": "profile.assessment.mental.ptsdIndicator", "operator": "eq", "value": true },
      "branches": [
        { "result": "true", "action_ids": ["act_men_018", "act_men_019"] }
      ]
    }
  ],
  "actions": [
    {
      "id": "act_men_001",
      "trigger": { "conditions": ["dt_men_001:true"] },
      "name": { "en": "Professional Help Referral", "es": "Derivación a Ayuda Profesional" },
      "steps": [
        { "order": 1, "instruction": { "en": "Reach out to a licensed therapist, counselor, or your bishop for mental health resources.", "es": "Contacte a un terapeuta licenciado, consejero o a su obispo para recursos de salud mental." } }
      ],
      "outcome_metric": "PROFESSIONAL_CONTACT",
      "priority": "critical"
    },
    {
      "id": "act_men_002",
      "trigger": { "conditions": ["dt_men_001:true"] },
      "name": { "en": "Daily Gratitude Journal", "es": "Diario de Gratitud Diario" },
      "steps": [
        { "order": 1, "instruction": { "en": "Write 3 specific things you are grateful for every morning.", "es": "Escriba 3 cosas específicas por las que está agradecido cada mañana." } }
      ],
      "outcome_metric": "GRATITUDE_PRACTICE",
      "repeat": "daily"
    },
    {
      "id": "act_men_003",
      "trigger": { "conditions": ["dt_men_001:true"] },
      "name": { "en": "Mood & Energy Check-in", "es": "Registro de Estado de Ánimo y Energía" },
      "steps": [
        { "order": 1, "instruction": { "en": "Rate mood 1-10 and note one trigger. Share with support person if low.", "es": "Califique el estado de ánimo del 1-10 y anote un desencadenante. Comparta con persona de apoyo si está bajo." } }
      ],
      "outcome_metric": "SELF_AWARENESS",
      "repeat": "daily"
    },
    {
      "id": "act_men_004",
      "trigger": { "conditions": ["dt_men_002:true"] },
