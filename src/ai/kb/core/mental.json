  "metrics": [
    {
      "id": "metric_men_001",
      "name": { "en": "Emotional Stability Score", "es": "Puntaje de Estabilidad Emocional" },
      "formula": "reverse of downFrequency normalized + emotionalSupport + resilienceScore",
      "target_range": { "min": 70, "max": 100 }
    },
    {
      "id": "metric_men_002",
      "name": { "en": "Gratitude Practice Consistency", "es": "Consistencia de Práctica de Gratitud" },
      "formula": "days with gratitude entry per week / 7 * 100",
      "target_range": { "min": 80, "max": 100, "unit": "percent" }
    }
  ]
}