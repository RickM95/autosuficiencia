    {
      "id": "act_fin_030",
      "trigger": { "conditions": [] },
      "name": { "en": "Create a Sinking Fund for Irregular Expenses", "es": "Crear un Fondo de Amortización para Gastos Irregulares" },
      "steps": [
        { "order": 1, "instruction": { "en": "Identify annual or surprise expenses (car repair, gifts, insurance) and divide by 12.", "es": "Identifique gastos anuales o sorpresivos (reparación del auto, regalos, seguro) y divídalos entre 12." } },
        { "order": 2, "instruction": { "en": "Set aside that amount monthly in a separate savings sub-account.", "es": "Aparte esa cantidad mensualmente en una subcuenta de ahorros separada." } }
      ],
