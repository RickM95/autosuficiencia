  ],
  "metrics": [
    {
      "id": "metric_fin_001",
      "name": { "en": "Savings Rate", "es": "Tasa de Ahorro" },
      "formula": "(monthlyNetIncome - monthlyTotalExpenses) / monthlyNetIncome * 100",
      "target_range": { "min": 10, "max": 50, "unit": "percent" }
    },
    {
      "id": "metric_fin_002",
      "name": { "en": "Emergency Fund Coverage (months)", "es": "Cobertura del Fondo de Emergencia (meses)" },
      "formula": "liquidSavings / monthlyFixedExpenses",
      "target_range": { "min": 3, "max": 6, "unit": "months" }
    },
    {
      "id": "metric_fin_003",
      "name": { "en": "Debt-to-Income Ratio", "es": "Relación Deuda-Ingreso" },
      "formula": "(sum of monthly debt payments) / monthlyNetIncome * 100",
      "target_range": { "min": 0, "max": 36, "unit": "percent", "warning": "Max 43% for most lenders" }
    },
    {
      "id": "metric_fin_004",
      "name": { "en": "Credit Score Trend", "es": "Tendencia del Puntaje Crediticio" },
      "formula": "currentScore - previousScore",
      "target_range": { "min": 0, "positive": true }
    }
  ]
